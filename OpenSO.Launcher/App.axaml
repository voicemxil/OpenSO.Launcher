<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OpenSO.Launcher.App"
             RequestedThemeVariant="Default">

  <!-- RequestedThemeVariant="Default" => follow the OS light/dark appearance. -->
  <Application.Styles>
    <FluentTheme />
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <!-- Light/dark adaptive palette: neutral grays + a single blue accent.
           Referenced everywhere via {DynamicResource} so it flips with the OS theme. -->
      <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Dark">
          <!-- Accent is the OpenSO teal. SystemAccentColor drives Fluent control accents (focus, ComboBox, etc.). -->
          <Color x:Key="SystemAccentColor">#3FD9D0</Color>
          <SolidColorBrush x:Key="Bg"     Color="#1C1C1E"/>
          <SolidColorBrush x:Key="Card"   Color="#2C2C2E"/>
          <SolidColorBrush x:Key="CardAlt" Color="#3A3A3C"/>
          <SolidColorBrush x:Key="Ink"    Color="#F5F5F7"/>
          <SolidColorBrush x:Key="Ink2"   Color="#AEAEB2"/>
          <SolidColorBrush x:Key="Ink3"   Color="#8E8E93"/>
          <SolidColorBrush x:Key="Line"   Color="#3A3A3C"/>
          <SolidColorBrush x:Key="Accent" Color="#3FD9D0"/>
          <SolidColorBrush x:Key="Track"  Color="#3A3A3C"/>
          <SolidColorBrush x:Key="Good"   Color="#30D158"/>
          <SolidColorBrush x:Key="Bad"    Color="#FF453A"/>
          <!-- Frosted-glass sidebar + nav hover/active tints (opacity lets the blur backdrop show through). -->
          <SolidColorBrush x:Key="SidebarBrush" Color="#1F2124" Opacity="0.78"/>
          <SolidColorBrush x:Key="SideHover"  Color="#FFFFFF" Opacity="0.13"/>
          <SolidColorBrush x:Key="SideActive" Color="#FFFFFF" Opacity="0.10"/>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
          <!-- A deeper teal for accent *text*, so it stays legible on white cards.
               Teal button fills use the constant bright TealFill below. -->
          <Color x:Key="SystemAccentColor">#0E8C84</Color>
          <SolidColorBrush x:Key="Bg"     Color="#F5F5F7"/>
          <SolidColorBrush x:Key="Card"   Color="#FFFFFF"/>
          <SolidColorBrush x:Key="CardAlt" Color="#ECECEF"/>
          <SolidColorBrush x:Key="Ink"    Color="#1D1D1F"/>
          <SolidColorBrush x:Key="Ink2"   Color="#6E6E73"/>
          <SolidColorBrush x:Key="Ink3"   Color="#8E8E93"/>
          <SolidColorBrush x:Key="Line"   Color="#E2E2E7"/>
          <SolidColorBrush x:Key="Accent" Color="#0E8C84"/>
          <SolidColorBrush x:Key="Track"  Color="#E5E5EA"/>
          <SolidColorBrush x:Key="Good"   Color="#34C759"/>
          <SolidColorBrush x:Key="Bad"    Color="#FF3B30"/>
          <!-- Light frosted sidebar + subtle dark nav tints. -->
          <SolidColorBrush x:Key="SidebarBrush" Color="#E9E9ED" Opacity="0.72"/>
          <SolidColorBrush x:Key="SideHover"  Color="#000000" Opacity="0.07"/>
          <SolidColorBrush x:Key="SideActive" Color="#000000" Opacity="0.05"/>
        </ResourceDictionary>

      </ResourceDictionary.ThemeDictionaries>

      <!-- Constant (theme-independent) brand tokens -->
      <!-- Brand teal button fill + dark ink (always bright, looks right on dark sidebar and light/dark content). -->
      <SolidColorBrush x:Key="TealFill" Color="#3FD9D0"/>
      <SolidColorBrush x:Key="TealInk"  Color="#063B3F"/>
      <!-- The themed navy backdrop (the old app background), reused behind the update prompt. -->
      <SolidColorBrush x:Key="UpdateBg"  Color="#0E2138"/>
      <SolidColorBrush x:Key="UpdateInk" Color="#E6F0F4"/>
      <!-- Error banner tint: translucent red so it reads on both light and dark cards (border/headline use Bad). -->
      <SolidColorBrush x:Key="ErrBg" Color="#FF453A" Opacity="0.13"/>
    </ResourceDictionary>
  </Application.Resources>
</Application>
