<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenSO.Launcher.ViewModels"
        xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        xmlns:models="using:OpenSO.Launcher.Models"
        xmlns:svc="using:OpenSO.Launcher.Services"
        x:Class="OpenSO.Launcher.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="960" Height="620" MinWidth="860" MinHeight="560"
        Title="OpenSO Launcher"
        Icon="avares://OpenSO.Launcher/Assets/openso.ico"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

  <Window.Styles>
    <!-- Sidebar nav buttons (sidebar is a fixed dark frosted panel, so its text is light) -->
    <Style Selector="Button.nav">
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource Ink2}"/>
      <Setter Property="BorderThickness" Value="3,0,0,0"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Padding" Value="17,11"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="0,8,8,0"/>
    </Style>
    <Style Selector="Button.nav:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SideHover}"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource Ink}"/>
    </Style>
    <Style Selector="Button.nav.active">
      <Setter Property="Background" Value="{DynamicResource SideActive}"/>
      <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource TealFill}"/>
    </Style>
    <!-- Keep the blue active indicator visible while the cursor is over (or pressing) the active tab. Fluent's
         pointerover/pressed states override the content presenter's BorderBrush, which hid the indicator under
         the mouse — it wasn't an animation delay, the indicator just vanished on hover. -->
    <Style Selector="Button.nav.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="BorderBrush" Value="{DynamicResource TealFill}"/>
    </Style>
    <Style Selector="Button.nav.active:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="BorderBrush" Value="{DynamicResource TealFill}"/>
    </Style>
    <!-- Section heading -->
    <Style Selector="TextBlock.h1">
      <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style Selector="TextBlock.sub"><Setter Property="Foreground" Value="{DynamicResource Ink2}"/><Setter Property="FontSize" Value="13"/><Setter Property="TextWrapping" Value="Wrap"/></Style>
    <Style Selector="TextBlock.label"><Setter Property="Foreground" Value="{DynamicResource Ink2}"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="12"/></Style>
    <!-- Emoji glyphs: force an emoji-capable font family so macOS renders Apple Color Emoji in color
         (the default system font's fallback doesn't pick it up). Keep it normal weight — Avalonia
         renders emoji monochrome at bold weights (AvaloniaUI/Avalonia#16839). -->
    <Style Selector="TextBlock.emoji"><Setter Property="FontFamily" Value="Apple Color Emoji, Segoe UI Emoji, Noto Color Emoji"/><Setter Property="FontSize" Value="22"/><Setter Property="VerticalAlignment" Value="Center"/></Style>
    <Style Selector="Border.card"><Setter Property="Background" Value="{DynamicResource Card}"/><Setter Property="BorderBrush" Value="{DynamicResource Line}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="12"/><Setter Property="Padding" Value="18,16"/></Style>
  </Window.Styles>

  <Grid ColumnDefinitions="232,*">

    <!-- ============ SIDEBAR (frosted glass) ============ -->
    <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
      <!-- Top inset (52) keeps the logo clear of the macOS traffic lights, which now float
           over the frosted sidebar (window client area extends under the decorations). -->
      <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
        <!-- Logo lockup. Source is set per theme in code-behind (on-dark vs on-light wordmark);
             Margin top is bumped on macOS to clear the traffic lights. -->
        <!-- Same 20px side margins as the PLAY button below, so the wordmark spans its exact width. -->
        <Image Grid.Row="0" x:Name="LogoImage"
               HorizontalAlignment="Stretch" Margin="20,22,20,8" Stretch="Uniform"/>

        <!-- PLAY -->
        <Button Grid.Row="1" Margin="20,12,20,6" Command="{Binding PrimaryActionCommand}" IsEnabled="{Binding !Busy}"
                Content="{Binding PlayButtonText}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                Background="{DynamicResource TealFill}" Foreground="{DynamicResource TealInk}" FontWeight="Bold" FontSize="16" Padding="0,12" CornerRadius="10"/>
        <TextBlock Grid.Row="2" Text="{Binding Clock}" Foreground="{DynamicResource Ink3}" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,2,0,14"/>

        <!-- Nav -->
        <StackPanel Grid.Row="3" Margin="0,4,0,0">
          <Button Classes="nav" Classes.active="{Binding IsHome}"          Command="{Binding NavigateCommand}" CommandParameter="HOME"          Content="Home"/>
          <Button Classes="nav" Classes.active="{Binding IsInstaller}"     Command="{Binding NavigateCommand}" CommandParameter="INSTALLER"     Content="Installer"/>
          <Button Classes="nav" Classes.active="{Binding IsDownloads}"     Command="{Binding NavigateCommand}" CommandParameter="DOWNLOADS"     Content="Downloads"/>
          <Button Classes="nav" Classes.active="{Binding IsSettings}"      Command="{Binding NavigateCommand}" CommandParameter="SETTINGS"      Content="Settings"/>
          <Button Classes="nav" Classes.active="{Binding IsNotifications}" Command="{Binding NavigateCommand}" CommandParameter="NOTIFICATIONS" Content="Notifications"/>
          <Button Classes="nav" Classes.active="{Binding IsAbout}"         Command="{Binding NavigateCommand}" CommandParameter="ABOUT"         Content="About"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="{Binding LauncherVersion}" Foreground="{DynamicResource Ink3}" FontSize="11" Margin="22,0,0,16"/>
      </Grid>
    </Border>

    <!-- ============ CONTENT ============ -->
    <Border Grid.Column="1" Background="{DynamicResource Bg}">
      <Grid x:Name="ContentRoot">

        <!-- HOME -->
        <ScrollViewer IsVisible="{Binding IsHome}" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="30,22,30,28" Spacing="16">
            <TextBlock Classes="h1" Text="Welcome to OpenSO"/>
            <TextBlock Classes="sub" Text="The Sims Online, reborn — free, fair, and built in the open."/>

            <Border Classes="card" Background="{DynamicResource UpdateBg}" BorderBrush="{DynamicResource TealFill}" BorderThickness="1"
                    IsVisible="{Binding HasUpdate}">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource UpdateInk}" TextWrapping="Wrap">
                  <Run Text="A new launcher version is available: "/><Run Text="{Binding UpdateVersion}" Foreground="{DynamicResource TealFill}" FontWeight="Bold"/>
                </TextBlock>
                <Button Grid.Column="1" Content="Update" Command="{Binding ApplyUpdateCommand}" IsEnabled="{Binding !Busy}"
                        Background="{DynamicResource TealFill}" Foreground="{DynamicResource TealInk}" FontWeight="Bold" Padding="16,6" CornerRadius="6"/>
              </Grid>
            </Border>

            <!-- Game (client) update required: installed version != the version the server runs -->
            <Border Classes="card" Background="{DynamicResource UpdateBg}" BorderBrush="{DynamicResource TealFill}" BorderThickness="1"
                    IsVisible="{Binding GameUpdateAvailable}">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource UpdateInk}" TextWrapping="Wrap">
                  <Run Text="A game update is required to play — the server is running "/><Run Text="{Binding ServerGameVersion}" Foreground="{DynamicResource TealFill}" FontWeight="Bold"/><Run Text="."/>
                </TextBlock>
                <Button Grid.Column="1" Content="Update Game" Command="{Binding PrimaryActionCommand}" IsEnabled="{Binding !Busy}"
                        Background="{DynamicResource TealFill}" Foreground="{DynamicResource TealInk}" FontWeight="Bold" Padding="16,6" CornerRadius="6"/>
              </Grid>
            </Border>

            <!-- LIVE SERVER STATS (polled from /userapi/status) -->
            <Border Classes="card">
              <StackPanel Spacing="14">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <TextBlock Grid.Column="0" Classes="label" Text="SERVER STATUS" VerticalAlignment="Center"/>
                  <!-- Manual refresh: forces an immediate status + update check. Shows '…' while a
                       refresh is in flight; disabled meanwhile so it can't double-fire. The caption next
                       to it shows when the stats on screen were last successfully loaded. -->
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="10,0,0,0" VerticalAlignment="Center">
                    <Button Padding="8,2" CornerRadius="6"
                            Command="{Binding RefreshStatusCommand}" IsEnabled="{Binding !IsRefreshing}"
                            Background="{DynamicResource CardAlt}" Foreground="{DynamicResource Accent}"
                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                            Content="{Binding RefreshButtonText}"/>
                    <TextBlock Text="{Binding LastUpdatedText}" Foreground="{DynamicResource Ink3}"
                               FontSize="11" VerticalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" Fill="{DynamicResource Good}" VerticalAlignment="Center" IsVisible="{Binding ServerOnline}"/>
                    <Ellipse Width="9" Height="9" Fill="{DynamicResource Bad}" VerticalAlignment="Center" IsVisible="{Binding !ServerOnline}"/>
                    <TextBlock Text="{Binding ServerName}" Foreground="{DynamicResource Ink}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ServerStatus}" Foreground="{DynamicResource Ink2}" VerticalAlignment="Center"/>
                  </StackPanel>
                </Grid>

                <!-- City map banner — the thumbnail.png shipped with the map, read from the local client
                     install (Content/Cities/city_{CityMapId}/). Collapsed until the client is installed. -->
                <Border CornerRadius="8" ClipToBounds="True" Height="110"
                        Background="{DynamicResource CardAlt}" IsVisible="{Binding HasCityThumbnail}">
                  <Image Source="{Binding CityThumbnail}" Stretch="UniformToFill"/>
                </Border>
                <Grid ColumnDefinitions="*,*,*">
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding PlayersOnline}" Foreground="{DynamicResource Accent}" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="players online" Foreground="{DynamicResource Ink3}" FontSize="12"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding LotsOnline}" Foreground="{DynamicResource Good}" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="lots online" Foreground="{DynamicResource Ink3}" FontSize="12"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding ServerTimeText}" Foreground="{DynamicResource Ink}" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="in-game time" Foreground="{DynamicResource Ink3}" FontSize="12"/>
                  </StackPanel>
                </Grid>
                <TextBlock Foreground="{DynamicResource Ink3}" FontSize="11">
                  <Run Text="Game version: "/><Run Text="{Binding ServerGameVersion}" Foreground="{DynamicResource Ink2}"/>
                </TextBlock>
              </StackPanel>
            </Border>

            <!-- BUSIEST LOTS -->
            <StackPanel IsVisible="{Binding StatsAvailable}" Spacing="6">
              <TextBlock Classes="label" Text="BUSIEST LOTS" Margin="0,4,0,2"/>
              <ItemsControl ItemsSource="{Binding TopLots}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:TopLot">
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,6" ColumnSpacing="10">
                      <Border Grid.Column="0" Width="42" Height="42" CornerRadius="5" ClipToBounds="True" Background="{DynamicResource CardAlt}">
                        <Image asyncImageLoader:ImageLoader.Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                      </Border>
                      <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource Ink}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Grid.Column="2" Text="{Binding Players}" Foreground="{DynamicResource Accent}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <TextBlock Classes="label" Text="LATEST NEWS" Margin="0,8,0,0"/>
            <ItemsControl ItemsSource="{Binding NewsItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="svc:NewsItem">
                  <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="{DynamicResource Card}"
                          BorderBrush="{DynamicResource Line}" BorderThickness="1"
                          CornerRadius="10" Padding="16,12" Margin="0,0,0,8" Cursor="Hand"
                          Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).OpenNewsCommand}"
                          CommandParameter="{Binding}">
                    <StackPanel>
                      <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Ink}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                      <TextBlock Text="{Binding Date}" Foreground="{DynamicResource Ink3}" FontSize="11" Margin="0,2,0,4"/>
                      <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource Ink2}" FontSize="12" TextWrapping="Wrap" MaxLines="3"/>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="Visit openso.org →" Command="{Binding OpenWebsiteCommand}" HorizontalAlignment="Left"
                    Background="Transparent" Foreground="{DynamicResource Accent}" FontWeight="SemiBold" Padding="0,4"/>
          </StackPanel>
        </ScrollViewer>

        <!-- INSTALLER -->
        <ScrollViewer IsVisible="{Binding IsInstaller}" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="30,22,30,28" Spacing="16">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="h1" Text="Installer"/>
                <TextBlock Classes="sub" Text="Install OpenSO and its dependencies."/>
              </StackPanel>
              <Button Grid.Column="1" VerticalAlignment="Center" Content="Complete Installation"
                      Command="{Binding InstallCommand}" IsEnabled="{Binding !Busy}"
                      Background="{DynamicResource TealFill}" Foreground="{DynamicResource TealInk}" FontWeight="Bold" Padding="18,9" CornerRadius="8"/>
            </Grid>

            <Border Classes="card">
              <Grid ColumnDefinitions="Auto,*,Auto" >
                <TextBlock Grid.Column="0" Classes="emoji" Text="🧩" Margin="0,0,14,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="OpenSO Client" Foreground="{DynamicResource Ink}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding ClientState}" Classes="sub" TextWrapping="Wrap"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding ClientInstalled}" VerticalAlignment="Center" Foreground="{DynamicResource Accent}" FontWeight="Bold"/>
              </Grid>
            </Border>
            <Border Classes="card">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Classes="emoji" Text="🎮" Margin="0,0,14,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="The Sims Online" Foreground="{DynamicResource Ink}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding AssetsState}" Classes="sub" TextWrapping="Wrap"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding AssetsInstalled}" VerticalAlignment="Center" Foreground="{DynamicResource Accent}" FontWeight="Bold"/>
              </Grid>
            </Border>
            <Border Classes="card">
              <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0" Classes="emoji" Text="🧊" Margin="0,0,14,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="3D Mesh Pack" Foreground="{DynamicResource Ink}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding RemeshState}" Classes="sub" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="2" Content="Install" Command="{Binding InstallRemeshCommand}" IsEnabled="{Binding !Busy}"
                        Background="{DynamicResource CardAlt}" Foreground="{DynamicResource Accent}" FontWeight="SemiBold" Padding="14,7" CornerRadius="6" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="3" Text="{Binding RemeshInstalled}" VerticalAlignment="Center" Foreground="{DynamicResource Accent}" FontWeight="Bold"/>
              </Grid>
            </Border>

            <TextBlock Classes="sub" TextWrapping="Wrap" Text="Installing the client also downloads the original TSO assets (~1.27 GB, from the Internet Archive) and the runtime dependencies for your platform. The 3D Mesh Pack is optional — it adds higher-quality 3D models used when 3D mode is enabled in Settings."/>
          </StackPanel>
        </ScrollViewer>

        <!-- DOWNLOADS -->
        <StackPanel IsVisible="{Binding IsDownloads}" Margin="30,22,30,28" Spacing="16">
          <TextBlock Classes="h1" Text="Downloads"/>
          <TextBlock Classes="sub" Text="Active downloads and installation progress."/>

          <!-- Loud error banner: a blocked/failed operation (e.g. a file locked by the running game)
               surfaces here in red with the specific cause, instead of raw exception text in the subtext. -->
          <Border Classes="card" IsVisible="{Binding HasError}"
                  Background="{DynamicResource ErrBg}" BorderBrush="{DynamicResource Bad}" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*">
              <TextBlock Grid.Column="0" Classes="emoji" Text="⚠️" Margin="0,0,14,0" VerticalAlignment="Top"/>
              <StackPanel Grid.Column="1" Spacing="3">
                <TextBlock Text="Couldn't complete the download" Foreground="{DynamicResource Bad}" FontWeight="Bold" FontSize="15"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource Ink}" TextWrapping="Wrap"/>
              </StackPanel>
            </Grid>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="10">
              <TextBlock Text="{Binding StatusLine}" Foreground="{DynamicResource Ink}" TextWrapping="Wrap"/>
              <ProgressBar Minimum="0" Maximum="1" Value="{Binding Progress}" Height="10"
                           IsIndeterminate="{Binding ProgressIndeterminate}"
                           Foreground="{DynamicResource Accent}" Background="{DynamicResource Track}"/>
              <TextBlock Text="{Binding ProgressDetail}" Classes="sub" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
          <TextBlock Classes="sub" Text="Nothing downloading right now." IsVisible="{Binding !Busy}"/>
        </StackPanel>

        <!-- SETTINGS -->
        <ScrollViewer IsVisible="{Binding IsSettings}" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="30,22,30,28" Spacing="16" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Classes="h1" Text="Settings"/>
            <TextBlock Classes="sub" Text="Personalize your game and launcher."/>

            <TextBlock Classes="label" Text="IN-GAME SETTINGS" Margin="0,8,0,0"/>
            <Border Classes="card">
              <StackPanel Spacing="14">
                <StackPanel Spacing="5">
                  <TextBlock Text="Graphics Mode" Foreground="{DynamicResource Ink}" FontWeight="SemiBold"/>
                  <ComboBox ItemsSource="{Binding GraphicsModes}" SelectedItem="{Binding GraphicsMode}" HorizontalAlignment="Stretch"/>
                  <TextBlock Classes="sub" Text="{Binding GraphicsModeHint}"/>
                </StackPanel>
                <StackPanel Spacing="5">
                  <TextBlock Text="3D Mode" Foreground="{DynamicResource Ink}" FontWeight="SemiBold"/>
                  <ComboBox ItemsSource="{Binding OnOff}" SelectedItem="{Binding ThreeDMode}" HorizontalAlignment="Stretch"/>
                  <TextBlock Classes="sub" Text="Best with the 3D Mesh Pack — install it from the Installer tab for higher-quality models."/>
                </StackPanel>
              </StackPanel>
            </Border>

            <TextBlock Classes="label" Text="LAUNCHER SETTINGS" Margin="0,8,0,0"/>
            <Border Classes="card">
              <StackPanel Spacing="14">
                <StackPanel Spacing="5">
                  <TextBlock Text="Automatic Launcher Updates" Foreground="{DynamicResource Ink}" FontWeight="SemiBold"/>
                  <ComboBox ItemsSource="{Binding OnOff}" SelectedItem="{Binding AutoUpdate}" HorizontalAlignment="Stretch"/>
                  <TextBlock Classes="sub" TextWrapping="Wrap" Text="When enabled, launcher updates install automatically at startup. When disabled, an update banner appears on the Home tab instead."/>
                </StackPanel>
                <StackPanel Spacing="5">
                  <TextBlock Text="Live Desktop Notifications" Foreground="{DynamicResource Ink}" FontWeight="SemiBold"/>
                  <ComboBox ItemsSource="{Binding OnOff}" SelectedItem="{Binding LiveNotifications}" HorizontalAlignment="Stretch"/>
                  <TextBlock Classes="sub" TextWrapping="Wrap" Text="Shows a desktop notification when a launcher or game update is detected (Windows and macOS)."/>
                </StackPanel>
                <StackPanel Spacing="5">
                  <TextBlock Text="Closing Behavior" Foreground="{DynamicResource Ink}" FontWeight="SemiBold"/>
                  <ComboBox ItemsSource="{Binding ClosingBehaviors}" SelectedItem="{Binding ClosingBehavior}" HorizontalAlignment="Stretch"/>
                  <TextBlock Classes="sub" TextWrapping="Wrap" Text="Minimize to tray keeps the launcher running in the notification area when you close the window."/>
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <!-- NOTIFICATIONS -->
        <StackPanel IsVisible="{Binding IsNotifications}" Margin="30,22,30,28" Spacing="14">
          <TextBlock Classes="h1" Text="Notifications"/>
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Notifications}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="card" Margin="0,0,0,8">
                    <TextBlock Text="{Binding}" Foreground="{DynamicResource Ink}" TextWrapping="Wrap"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
          <TextBlock Classes="sub" Text="No notifications yet." IsVisible="{Binding !Notifications.Count}"/>
        </StackPanel>

        <!-- ABOUT -->
        <StackPanel IsVisible="{Binding IsAbout}" Margin="30,22,30,28" Spacing="14">
          <TextBlock Classes="h1" Text="About"/>
          <Border Classes="card">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding LauncherVersion}" Foreground="{DynamicResource Ink}" FontWeight="SemiBold"/>
              <TextBlock Classes="sub" TextWrapping="Wrap"
                         Text="OpenSO is a modernized, community-run revival of The Sims Online — free, fair, and built in the open. This launcher installs the OpenSO client and the original TSO game assets, keeps them up to date, and launches the game."/>
              <TextBlock Classes="sub" TextWrapping="Wrap" Text="Built on FreeSO. Not affiliated with EA or Maxis."/>
              <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,6,0,0">
                <Button Content="openso.org" Command="{Binding OpenWebsiteCommand}" Background="{DynamicResource CardAlt}" Foreground="{DynamicResource Accent}" Padding="14,7" CornerRadius="6"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

      </Grid>
    </Border>

    <!-- macOS only: a draggable title-bar strip. The extended client area has no native title bar to
         drag the window by, so this transparent strip calls BeginMoveDrag (wired in code-behind). It's
         left-inset to clear the traffic lights and hidden on Windows/Linux (which keep a native title bar). -->
    <Border x:Name="MacDragBar" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Top"
            Height="30" Margin="78,0,0,0" Background="Transparent" IsVisible="False"/>
  </Grid>
</Window>
